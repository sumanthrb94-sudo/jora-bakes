rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: id, category, name, description, price, weight, isEggless, isAvailable, bakeTime, allergens, images, ingredients, shelfLife, storage, pairings, isBestSeller, isNew
    //
    // Collection: users
    // Fields: uid, email, name, phone, role, points, createdAt
    //
    // Collection: orders
    // Fields: id, userId, items, total, status, createdAt, deliveryDate, deliverySlot
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sumanthrb94@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category in ['cakes', 'brownies', 'cookies', 'bread', 'loaves', 'custom'];
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'customer'];
    }

    function isValidOrder(data) {
      let isGuest = data.userId == 'guest';
      let isAuthUser = isAuthenticated() && data.userId == request.auth.uid;
      return (isGuest || isAuthUser) &&
             data.total is number && data.total >= 0 &&
             data.status in ['received', 'confirmed', 'baking', 'quality_check', 'out_for_delivery', 'delivered'] &&
             data.items is list && data.items.size() > 0;
    }

    // Rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'customer' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /orders/{orderId} {
      // NOTE: Querying orders by userId and ordering by createdAt requires a composite index:
      // Collection: orders, Fields: userId (Ascending), createdAt (Descending)
      allow read: if resource.data.userId == 'guest' || (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Only system/admin can create notifications
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
