# Firebase Configuration
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_FIRESTORE_DB_ID="YOUR_FIRESTORE_DB_ID"

# Admin Emails (comma-separated)
VITE_ADMIN_EMAILS="admin1@gmail.com,admin2@gmail.com"

# Cashfree Payment Gateway
# Get test credentials from: https://merchant.cashfree.com → Developers → API Keys (Test mode)
CASHFREE_APP_ID="TEST_APP_ID_HERE"
CASHFREE_SECRET_KEY="TEST_SECRET_KEY_HERE"
# Set to PRODUCTION when going live, keep as TEST for sandbox
CASHFREE_ENV="TEST"

# App URL for Cashfree return_url (no trailing slash)
APP_URL="http://localhost:3000"

# Frontend — exposes sandbox/production mode to the JS SDK
VITE_CASHFREE_ENV="TEST"
