rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Check if the user is the admin by email
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'sumanthbolla97@gmail.com' ||
        request.auth.token.email == 'alekhya.cla@gmail.com' ||
        request.auth.token.email == 'newadmin@gmail.com'
      );
    }

    // Profile pictures — only authenticated users can view, owner or admin can upload
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Product images — anyone can view, only admins can upload (with validation)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
