rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Check if the user is the admin by email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'sumanthbolla97@gmail.com';
    }

    // Allow anyone to read profile pictures, but only the owner can upload/delete them
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow anyone to see product images, but only admins can upload/delete
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
